# GEMINI_API_KEY= # Reservado para integração futura com LLM - não usar em produção ainda

# VITE_TELEMETRY_ENDPOINT (optional): endpoint HTTP para receber eventos de telemetria.
# Se não for definido, a aplicação continua funcional e registra eventos apenas em localStorage.
VITE_TELEMETRY_ENDPOINT=""

# VITE_FEATURE_DECISION_API (optional): ativa fachada backend da triagem em /api/triage/resolve.
# Fallback local permanece obrigatório e é usado automaticamente em falhas/offline.
VITE_FEATURE_DECISION_API="false"
# Alias opcional para o mesmo comportamento:
VITE_FEATURE_TRIAGE_API="false"

# VITE_FEATURE_SEARCH_API (optional): ativa fachada backend da busca em /api/search.
# Fallback local permanece obrigatório e é usado automaticamente em falhas/offline.
VITE_FEATURE_SEARCH_API="false"

# VITE_FEATURE_NETWORK_API (optional): ativa fachada backend da rede em /api/network/services.
# Fallback local permanece obrigatório e é usado automaticamente em falhas/offline.
VITE_FEATURE_NETWORK_API="false"

# VITE_FEATURE_CONTENT_BOOTSTRAP_API (optional): ativa fachada de bootstrap em /api/content/bootstrap.
# Fallback local permanece obrigatório e é usado automaticamente em falhas/offline.
VITE_FEATURE_CONTENT_BOOTSTRAP_API="false"
